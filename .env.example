# Public Vite client configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-public-client-key

# demo | live | unavailable
VITE_VORTA_DATA_MODE=demo

# Keep false until the Core Capability + Asset Competence preview has passed review.
VITE_SKILLS_MATRIX_CORE_ASSET_PREVIEW=false

# Optional authenticated Playwright configuration
VORTA_E2E_EMAIL=pilot-test-user@example.invalid
VORTA_E2E_PASSWORD=replace-locally
VORTA_E2E_SITE_ID=replace-with-authorised-site-id
VORTA_E2E_DENIED_SITE_ID=replace-with-denied-site-id
VORTA_E2E_DENIED_EQUIPMENT_ID=replace-with-denied-equipment-id

# Leave blank to let Playwright start the local Vite server.
VORTA_E2E_BASE_URL=
