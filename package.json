{
  "version": "1.0.0",
  "type": "module",
  "source": "./index.html",
  "name": "vorta-mvp",
  "description": "Vorta maintenance and reliability intelligence MVP",
  "scripts": {
    "dev": "vite",
    "repair:legacy-workflows": "node scripts/apply-skills-matrix-data-trust-fix.mjs && node scripts/repair-skills-matrix-workflow-codemod.mjs && node scripts/apply-skills-matrix-workflow-fix.mjs && node scripts/apply-equipment-people-workflow-fix.mjs",
    "typecheck": "tsc -p tsconfig.maintenance.json",
    "test:contracts": "node scripts/run-contract-suite.mjs",
    "test:smoke": "node scripts/runtime-route-smoke-tests.mjs",
    "test:browser": "playwright test --config=playwright.config.ts",
    "test:performance": "node scripts/check-performance-budgets.mjs",
    "prebuild": "node scripts/validate-live-pilot.mjs",
    "build:metadata": "node scripts/write-build-metadata.mjs",
    "build": "python3 scripts/apply-mobile-header-risk-picker-fix.py && npm run build:metadata && npm run typecheck && npm run test:contracts && npm run test:smoke && vite build",
    "postbuild": "npm run test:performance",
    "check": "npm run build"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.2.0",
    "react-dom": "^18.3.7",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "2.5.4",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.1.4",
    "esbuild": "0.27.3",
    "globals": "15.15.0",
    "tailwindcss": "3.4.16",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  },
  "alias": {
    "@/*": "./src/components/ui/$1"
  }
}
