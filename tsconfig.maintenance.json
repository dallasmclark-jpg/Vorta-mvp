{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "types": ["vite/client"]
  },
  "include": [
    "src/lib/accessControl.ts",
    "src/lib/runtimeContracts.ts",
    "src/lib/maintenanceActions.ts",
    "src/hooks/useModalFocusTrap.ts"
  ]
}
